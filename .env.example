# Copie ce fichier en .env et remplis les valeurs

# Adresse Gmail qui envoie l'email
EMAIL_SENDER=ton.adresse@gmail.com

# App Password Gmail (pas ton mot de passe Gmail normal)
# Pour le créer : Google Account → Sécurité → Mots de passe d'application
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Adresse qui reçoit l'email (peut être la même que EMAIL_SENDER)
EMAIL_RECIPIENT=toi@example.com

# Nombre de jours en arrière à analyser (défaut : 7)
DAYS_BACK=7
